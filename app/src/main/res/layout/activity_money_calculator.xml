<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teal_50">

    <!-- Main content -->


        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Toolbar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/teal_700"
                app:title="Money for Time"
                app:titleCentered="true"
                app:titleTextColor="@android:color/white"
                app:navigationIcon="@drawable/ic_menu"
                app:navigationIconTint="@android:color/white" />

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/teal_200"
                app:cardBackgroundColor="@color/teal_70">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Time Worked -->
                    <TextView
                        android:text="⏱ Time Worked"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/teal_800"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etTimeWorked"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="HH:MM"
                        android:inputType="time"
                        android:padding="16dp"
                        android:background="@drawable/edittext_border"
                        android:textColor="@color/black"
                        android:textSize="18sp"/>

                    <!-- Rate per Hour -->
                    <TextView
                        android:text="💰 Rate per Hour"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/teal_800"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etRatePerHour"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter amount (₹)"
                        android:inputType="numberDecimal"
                        android:padding="16dp"
                        android:background="@drawable/edittext_border"
                        android:textColor="@color/black"
                        android:textSize="18sp"/>
                    <!-- Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculateEarnings"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Calculate Earnings"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginTop="28dp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/teal_700"
                        android:textColor="@android:color/white"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Result Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="30dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/teal_300"
                app:cardBackgroundColor="@color/teal_700">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvResultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculation Result"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Result will appear here"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:lineSpacingExtra="6dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/white"
        android:paddingBottom="16dp"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemTextColor="@color/black"
        app:itemIconTint="@null"
        app:itemBackground="@drawable/nav_item_bg"
        app:itemHorizontalPadding="20dp"
        app:itemIconPadding="16dp"
        app:itemVerticalPadding="15dp"/>

</androidx.drawerlayout.widget.DrawerLayout>