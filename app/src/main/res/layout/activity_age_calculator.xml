<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teal_50">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/teal_700"
            app:title="Find Your Age"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="@android:color/white" />

        <!-- MAIN INPUT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/teal_200"
            app:cardBackgroundColor="@color/teal_70">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- DOB TITLE -->
                <TextView
                    android:text="Date of Birth"
                    android:textStyle="bold"
                    android:textColor="@color/teal_700"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- DOB SPINNER CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/teal_200"
                    app:cardBackgroundColor="@color/teal_50">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- DAY -->
                        <Spinner
                            android:id="@+id/spinnerDobDay"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:layout_marginEnd="6dp"
                            android:padding="6dp"/>

                        <!-- MONTH -->
                        <Spinner
                            android:id="@+id/spinnerDobMonth"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:layout_marginEnd="6dp"
                            android:padding="6dp"/>

                        <!-- YEAR -->
                        <Spinner
                            android:id="@+id/spinnerDobYear"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:padding="6dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- TARGET TITLE -->
                <TextView
                    android:text="Age at the Date of"
                    android:textStyle="bold"
                    android:textColor="@color/teal_700"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- TARGET SPINNER CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/teal_200"
                    app:cardBackgroundColor="@color/teal_50">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- TARGET DAY -->
                        <Spinner
                            android:id="@+id/spinnerTargetDay"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:layout_marginEnd="6dp"
                            android:padding="6dp"/>

                        <!-- TARGET MONTH -->
                        <Spinner
                            android:id="@+id/spinnerTargetMonth"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:layout_marginEnd="6dp"
                            android:padding="6dp"/>

                        <!-- TARGET YEAR -->
                        <Spinner
                            android:id="@+id/spinnerTargetYear"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/spinner_white_bg"
                            android:padding="6dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <!-- CALCULATE BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_calculate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CALCULATE AGE"
                    android:textAllCaps="false"
                    android:minHeight="52dp"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:backgroundTint="@color/teal_700"
                    android:textColor="@android:color/white"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RESULT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/teal_700">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center"
                android:text="Your Age will appear here"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/white"

        android:paddingBottom="16dp"

        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"

        app:itemTextColor="@color/black"
        app:itemIconTint="@null"

        app:itemBackground="@drawable/nav_item_bg"
        app:itemHorizontalPadding="20dp"
        app:itemIconPadding="16dp"
        app:itemVerticalPadding="15dp"/>

</androidx.drawerlayout.widget.DrawerLayout>
